# ================================================================
# GestionBeach - Variables de entorno para Docker
# ================================================================
# Copiar este archivo como .env en la raíz del proyecto:
#   cp .env.docker.example .env
# ================================================================

# Contraseña para SQL Server (debe coincidir con DB_PASS en backend/.env)
# SQL Server REQUIERE: mayúsculas + minúsculas + números + símbolo especial
# IMPORTANTE: el password actual en backend/.env (*1beachmarket) NO tiene mayúsculas
# → cambia AMBOS: este SA_PASSWORD y el DB_PASS en backend/.env al mismo valor
SA_PASSWORD=*1Beachmarket
